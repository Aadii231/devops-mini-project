aws_region       = "us-east-1"
environment      = "dev"
project_name     = "devops-mini-project"
instance_type    = "t3.medium"
key_pair_name    = "my-ec2-keypair"   # must already exist in your AWS account
ssh_cidr         = "YOUR_IP/32"        # replace with your IP for security
root_volume_size = 30
